# ─────────────────────────────────────────────────────────────────────────────
# .env – environment overrides for the free-tools trading agent
# ─────────────────────────────────────────────────────────────────────────────
#
# Copy this file to .env and edit the values if needed.
# All settings here are OPTIONAL – the system runs with sensible defaults.
#
# No paid API keys are required when using Ollama + yfinance.

# ── Ollama model selection ────────────────────────────────────────────────────
# Set these to any model name you have pulled locally with `ollama pull <model>`.
# Recommended models (good balance of performance vs. resource use):
#   llama3.1:8b   – best overall for financial reasoning (requires ~8 GB RAM)
#   qwen2.5:7b    – strong reasoning, slightly smaller
#   mistral:7b    – fast and capable
#   qwen2.5:3b    – lightweight option for machines with <8 GB RAM

DEEP_THINK_MODEL=llama3.1:8b
QUICK_THINK_MODEL=llama3.1:8b

# ── Ollama server URL ─────────────────────────────────────────────────────────
# Change only if your Ollama instance runs on a non-standard host/port.
# OLLAMA_BASE_URL=http://localhost:11434/v1
